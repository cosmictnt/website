---
const profilePic = "/lucamarsh.png"
const logo = "/bg-studio-logo.png"
---

<style is:global>
:root {
  --light:#DFDD8A;
  --mid:#939051;
  --deep:#151402;
}

html,body{
  margin:0;
  background:var(--deep);
  color:var(--light);
  font-family:Inter, sans-serif;
  /* allow scrolling on small devices */
  overflow:auto;
}

/* LAYOUT */
#layout{display:flex; height:100vh; align-items:stretch; gap:2rem}

/* LEFT */
#left{
  width:40%;
  padding:1.5rem 1.75rem;
  display:flex;
  flex-direction:column;
  gap:1.25rem;
  justify-content:center;
}

/* LOGO */
#logo{width:180px; max-width:40vw}

/* CONTENT */
.content{display:flex;gap:2rem;align-items:center}

/* CRT */
/* CRT bezel: stronger retro TV styling */
.crt-frame{
  /* convert CRT to a clean UI card while preserving the portrait */
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:10px;
  background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
  border-radius:12px;
  box-shadow: 0 8px 20px rgba(2,6,23,0.6);
  border:1px solid rgba(255,255,255,0.03);
  position:relative;
}

/* controls removed (buttons intentionally deleted) */

/* SCREEN */

/* screen: curved glass effect + inner glow */
.screen{
  width:150px;
  height:150px;
  background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.03), transparent 20%),
              linear-gradient(#060606, #000000);
  overflow:hidden;
  position:relative;
  border-radius:18px; /* more rounded like old CRT masks */
  box-shadow: inset 0 -12px 24px rgba(0,0,0,0.7), inset 0 8px 20px rgba(255,255,255,0.02);
  border: 2px solid rgba(0,0,0,0.6);
}

.screen img{
  width:110%;
  height:110%;
  object-fit:cover;
  transform: translate(-5%, -5%);
  filter: contrast(1.1) brightness(0.85) saturate(0.95);
  display:block;
}

/* glass/scanline overlays stay above the image */
.screen .scanlines{ mix-blend-mode:overlay }
.screen .vignette{ pointer-events:none }

.scanlines{
  position:absolute;
  inset:0;
  background:repeating-linear-gradient(
    to bottom,
    rgba(255,255,255,0.04),
    transparent 2px
  );
}

.vignette{
  position:absolute;
  inset:0;
  box-shadow:
    inset 0 0 30px rgba(0,0,0,0.9),
    inset 0 0 60px rgba(0,0,0,0.6);
}

.glass{
  position:absolute;
  inset:0;
  background:radial-gradient(
    circle at center,
    transparent 60%,
    rgba(0,0,0,0.25)
  );
}

/* TEXT */
h1{margin:0;font-size:2.4rem}
h2{color:var(--mid);margin:.5rem 0}
p{max-width:300px;color:#cfcf9a}

/* BUTTONS */
.big-buttons{
  display:flex;
  gap:1rem;
  margin-top:1.2rem;
}

.big-box{
  flex:1;
  text-align:center;
  padding:18px 10px;
  border:1px solid rgba(147,144,81,0.4);
  text-decoration:none;
  color:var(--light);
  font-weight:600;
  letter-spacing:1px;
  transition:0.25s;
  background:rgba(0,0,0,0.3);
}

.big-box:hover{
  background:var(--mid);
  color:var(--deep);
  box-shadow:0 0 12px var(--mid);
  transform:translateY(-2px);
}

/* DIVIDER */
.section-divider{
  height:1px;
  background:linear-gradient(to right, transparent, var(--mid), transparent);
  box-shadow:0 0 8px var(--mid);
  opacity:.6;
}

/* EXPERIENCE */
#experience {
  margin-top: 1rem;
}

.exp-box {
  border: 1px solid rgba(147,144,81,0.3);
  padding: 12px;
  background: rgba(0,0,0,0.25);
  box-shadow: inset 0 0 10px rgba(0,0,0,0.6);
}

.exp-box h4 {
  margin: 0;
  font-size: 1rem;
  color: var(--light);
}

.year {
  margin: 4px 0 10px;
  color: var(--mid);
  font-size: 0.85rem;
}

.exp-box p {
  color: #cfcf9a;
  max-width: 100%;
}

.exp-box ul {
  margin: 8px 0 0;
  padding-left: 18px;
  color: #cfcf9a;
}

.exp-box li {
  margin-bottom: 4px;
  font-size: 0.9rem;
}

/* SOFTWARE */
#software {
  margin-top: 1rem;
}

.grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:8px;
}

.grid a{
  padding:8px 10px;
  font-size:.95rem;
  border:1px solid rgba(255,255,255,0.04);
  text-decoration:none;
  color:var(--light);
  transition: background .18s, transform .18s;
  border-radius:8px;
  background: rgba(255,255,255,0.01);
}

.grid a:hover{
  background: rgba(96,165,250,0.08);
  color:var(--light);
  transform: translateY(-2px);
}

/* SOCIAL MEDIA */
#social {
  margin-top: 1rem;
}

#social .grid a{
  display:block;
  text-align:center;
}

/* MAIN DIVIDER */
#divider{
  width:2px;
  background:var(--mid);
  opacity:.4;
}

/* RIGHT (show reel + social stacked) */
#right{
  width:60%;
  background:black;
  display:flex;
  flex-direction:column;
  gap:1rem;
  align-items:stretch;
}

.show-reel{
  flex:1 1 auto;
  min-height:75vh; /* larger desktop show reel for better balance */
  width:100%;
  background:transparent;
}

.show-reel{ display:flex; align-items:center; justify-content:center }

#right iframe{
  width:100%;
  height:100%;
  border:none;
  display:block;
}

/* responsive video wrapper to preserve aspect ratio and avoid squashing on mobile */
.video-wrapper{
  width:100%;
  max-width:100%;
  aspect-ratio: 16 / 9;
  background: #000;
}

.video-wrapper iframe{
  width:100%;
  height:100%;
  border:0;
  display:block;
}

@media (min-width: 900px) {
  /* On larger screens, let the wrapper fill the show-reel height so the iframe isn't limited by aspect-ratio */
  .video-wrapper{ aspect-ratio: auto; height:100%; }
}

/* visual separation between show reel and social */
.reel-divider{
  height:1px;
  width:100%;
  margin:6px 0;
  background: linear-gradient(to right, transparent, rgba(147,144,81,0.12), transparent);
}

/* social card to separate from show reel */
#social{
  margin:0;
  padding:12px;
  background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
  border-radius:8px;
  border:1px solid rgba(255,255,255,0.03);
  box-shadow: 0 6px 18px rgba(0,0,0,0.45);
}

#social h3{
  margin:0 0 8px 0;
  font-size:1rem;
  color:var(--light);
}

#social .grid{ margin-top:6px }

/* =========================
   ✨ Subtle brightness variation for buttons
   - Apply small brightness differences per-button so the UI feels textured
   - Use a gentler hover (no !important) that brightens and lifts the element
   ========================= */

/* big-buttons (hero CTA buttons) — small, pleasant variance */
.big-buttons .big-box:nth-child(1) { filter: brightness(1.04); }
.big-buttons .big-box:nth-child(2) { filter: brightness(0.99); }
.big-buttons .big-box:nth-child(3) { filter: brightness(1.01); }
.big-buttons .big-box:nth-child(4) { filter: brightness(0.97); }

/* grid links (software / social lists) — keep the existing stagger */
.grid a:nth-child(1){ filter: brightness(1.06); }
.grid a:nth-child(2){ filter: brightness(0.96); }
.grid a:nth-child(3){ filter: brightness(1.02); }
.grid a:nth-child(4){ filter: brightness(0.94); }
.grid a:nth-child(5){ filter: brightness(1.08); }
.grid a:nth-child(6){ filter: brightness(0.98); }
.grid a:nth-child(7){ filter: brightness(1.03); }
.grid a:nth-child(8){ filter: brightness(0.95); }
.grid a:nth-child(9){ filter: brightness(1.07); }
.grid a:nth-child(10){ filter: brightness(0.93); }
.grid a:nth-child(11){ filter: brightness(1.01); }
.grid a:nth-child(12){ filter: brightness(0.97); }

/* hover: brighten and add a soft shadow/lift (avoid !important) */
.big-box:hover{
  filter: brightness(1.12);
  box-shadow: 0 8px 20px rgba(0,0,0,0.5);
  transform: translateY(-2px);
}

.grid a:hover{
  filter: brightness(1.12);
  box-shadow: 0 6px 14px rgba(0,0,0,0.45);
}

/* ----------------------
   Responsive / Mobile
   ---------------------- */
@media (max-width: 900px) {
  #layout { flex-direction: column; height: auto; min-height:100vh }
  #left, #right { width:100% }
  #left { padding:1rem }
  #logo { width:140px }
  .content { flex-direction:row; gap:1rem }
  .screen { width:120px; height:120px }
  h1 { font-size:1.6rem }
  h2 { font-size:1rem }
  p { max-width:100% }
  .big-buttons { flex-direction:column }
  .big-box { width:100%; padding:12px }
  .grid { grid-template-columns:repeat(2,1fr) }
  .show-reel { min-height:40vh }
  #right iframe { height:100% }
}

@media (max-width: 480px) {
  .content { flex-direction:column; align-items:flex-start }
  .screen { width:100px; height:100px }
  h1 { font-size:1.4rem }
  .grid { grid-template-columns:repeat(1,1fr); gap:8px }
  .show-reel { min-height:35vh }
}

</style>

