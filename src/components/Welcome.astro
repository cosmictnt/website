---
const profilePic = "/lucamarsh.png"
const logo = "/bg-studio-logo.png"
---

<style is:global>
:root {
  --light:#DFDD8A;
  --mid:#939051;
  --deep:#151402;
}

html,body{
  margin:0;
  background:var(--deep);
  color:var(--light);
  font-family:Inter, sans-serif;
  /* allow scrolling on small devices */
  overflow:auto;
}

/* LAYOUT */
#layout{display:flex; height:100vh; align-items:stretch}

/* LEFT */
#left{
  width:40%;
  padding:2rem;
  display:flex;
  flex-direction:column;
  gap:1.5rem;
}

/* LOGO */
#logo{width:180px; max-width:40vw}

/* CONTENT */
.content{display:flex;gap:2rem;align-items:center}

/* CRT */
.crt-frame{
  padding:14px;
  background: linear-gradient(145deg,
    #e7dfc6 0%,
    #d8cfb2 35%,
    #cbbf9f 100%);
  border-radius:10px;
  box-shadow:
    inset 0 2px 6px rgba(255,255,255,0.25),
    inset 0 -4px 10px rgba(0,0,0,0.25),
    0 12px 30px rgba(0,0,0,0.6);
  border:1px solid rgba(90,80,50,0.25);
}

/* SCREEN */
.screen{
  width:150px;
  height:150px;
  background:black;
  overflow:hidden;
  position:relative;
  border-radius:6px;
}

.screen img{
  width:100%;
  height:100%;
  object-fit:cover;
  filter:contrast(1.15) brightness(0.9) saturate(0.9);
}

.scanlines{
  position:absolute;
  inset:0;
  background:repeating-linear-gradient(
    to bottom,
    rgba(255,255,255,0.04),
    transparent 2px
  );
}

.vignette{
  position:absolute;
  inset:0;
  box-shadow:
    inset 0 0 30px rgba(0,0,0,0.9),
    inset 0 0 60px rgba(0,0,0,0.6);
}

.glass{
  position:absolute;
  inset:0;
  background:radial-gradient(
    circle at center,
    transparent 60%,
    rgba(0,0,0,0.25)
  );
}

/* TEXT */
h1{margin:0;font-size:2.4rem}
h2{color:var(--mid);margin:.5rem 0}
p{max-width:300px;color:#cfcf9a}

/* BUTTONS */
.big-buttons{
  display:flex;
  gap:1rem;
  margin-top:1.2rem;
}

.big-box{
  flex:1;
  text-align:center;
  padding:18px 10px;
  border:1px solid rgba(147,144,81,0.4);
  text-decoration:none;
  color:var(--light);
  font-weight:600;
  letter-spacing:1px;
  transition:0.25s;
  background:rgba(0,0,0,0.3);
}

.big-box:hover{
  background:var(--mid);
  color:var(--deep);
  box-shadow:0 0 12px var(--mid);
  transform:translateY(-2px);
}

/* DIVIDER */
.section-divider{
  height:1px;
  background:linear-gradient(to right, transparent, var(--mid), transparent);
  box-shadow:0 0 8px var(--mid);
  opacity:.6;
}

/* EXPERIENCE */
#experience {
  margin-top: 1rem;
}

.exp-box {
  border: 1px solid rgba(147,144,81,0.3);
  padding: 12px;
  background: rgba(0,0,0,0.25);
  box-shadow: inset 0 0 10px rgba(0,0,0,0.6);
}

.exp-box h4 {
  margin: 0;
  font-size: 1rem;
  color: var(--light);
}

.year {
  margin: 4px 0 10px;
  color: var(--mid);
  font-size: 0.85rem;
}

.exp-box p {
  color: #cfcf9a;
  max-width: 100%;
}

.exp-box ul {
  margin: 8px 0 0;
  padding-left: 18px;
  color: #cfcf9a;
}

.exp-box li {
  margin-bottom: 4px;
  font-size: 0.9rem;
}

/* SOFTWARE */
#software {
  margin-top: 1rem;
}

.grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:6px;
}

.grid a{
  padding:6px;
  font-size:.85rem;
  border:1px solid rgba(147,144,81,0.3);
  text-decoration:none;
  color:var(--light);
  transition:.2s;
}

.grid a:hover{
  background:black;
  color:var(--mid);
  border-color:var(--mid);
  box-shadow:0 0 6px var(--mid);
}

/* SOCIAL MEDIA */
#social {
  margin-top: 1rem;
}

#social .grid a{
  display:block;
  text-align:center;
}

/* MAIN DIVIDER */
#divider{
  width:2px;
  background:var(--mid);
  opacity:.4;
}

/* RIGHT */
#right{
  width:60%;
  background:black;
}

#right iframe{
  width:100%;
  height:100%;
  border:none;
}

/* =========================
   \u2728 ADDED: SUBTLE BRIGHTNESS VARIATION
   ========================= */

.big-box:nth-child(1),
.grid a:nth-child(1){
  filter: brightness(1.06);
}

.big-box:nth-child(2),
.grid a:nth-child(2){
  filter: brightness(0.96);
}

.grid a:nth-child(3){
  filter: brightness(1.02);
}

.grid a:nth-child(4){
  filter: brightness(0.94);
}

.grid a:nth-child(5){
  filter: brightness(1.08);
}

.grid a:nth-child(6){
  filter: brightness(0.98);
}

.grid a:nth-child(7){
  filter: brightness(1.03);
}

.grid a:nth-child(8){
  filter: brightness(0.95);
}

.grid a:nth-child(9){
  filter: brightness(1.07);
}

.grid a:nth-child(10){
  filter: brightness(0.93);
}

.grid a:nth-child(11){
  filter: brightness(1.01);
}

.grid a:nth-child(12){
  filter: brightness(0.97);
}

/* hover override */
.big-box:hover,
.grid a:hover{
  filter: brightness(1.15) !important;
}

/* ----------------------
   Responsive / Mobile
   ---------------------- */
@media (max-width: 900px) {
  #layout { flex-direction: column; height: auto; min-height:100vh }
  #left, #right { width:100% }
  #left { padding:1rem }
  #logo { width:140px }
  .content { flex-direction:row; gap:1rem }
  .screen { width:120px; height:120px }
  h1 { font-size:1.6rem }
  h2 { font-size:1rem }
  p { max-width:100% }
  .big-buttons { flex-direction:column }
  .big-box { width:100%; padding:12px }
  .grid { grid-template-columns:repeat(2,1fr) }
  #right { height:40vh }
  #right iframe { height:100% }
}

@media (max-width: 480px) {
  .content { flex-direction:column; align-items:flex-start }
  .screen { width:100px; height:100px }
  h1 { font-size:1.4rem }
  .grid { grid-template-columns:repeat(1,1fr) }
  #right { height:35vh }
}

</style>

